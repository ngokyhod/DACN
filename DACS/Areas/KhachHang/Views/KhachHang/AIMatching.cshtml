@model DACS.Models.ViewModels.KhachHangDashboardViewModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "AI Matching";
    var currentUser = await UserManager.GetUserAsync(User);
    var displayName = Model?.TenNguoiMua ?? currentUser?.FullName ?? User.Identity?.Name ?? "Khách";
}

<div class="container mt-4 account-section">
    <div class="row">
        <div class="col-lg-3 mb-4 mb-lg-0">
            <div class="account-menu list-group">
                <a asp-area="KhachHang" asp-controller="KhachHang" asp-action="Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="fas fa-tachometer-alt fa-fw me-2"></i> Tổng quan
                </a>
                <a asp-area="KhachHang" asp-controller="KhachHang" asp-action="HoSoCaNhan" class="list-group-item list-group-item-action">
                    <i class="fas fa-user-circle fa-fw me-2"></i> Hồ sơ cá nhân
                </a>
                <a asp-area="KhachHang" asp-controller="KhachHang" asp-action="DangKyDoanhNghiep" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Action"]?.ToString() == "DangKyDoanhNghiep" ? "active" : "")">
                    <i class="fas fa-building fa-fw me-2"></i> Đăng ký Doanh nghiệp
                </a>
                <a asp-area="KhachHang" asp-controller="KhachHang" asp-action="LichSuDonHang" class="list-group-item list-group-item-action">
                    <i class="fas fa-receipt fa-fw me-2"></i> Lịch sử Đơn hàng
                </a>
                <a asp-area="KhachHang" asp-controller="KhachHang" asp-action="AIMatching" class="list-group-item list-group-item-action active">
                    <i class="fas fa-robot fa-fw me-2 text-success"></i> AI Matching
                </a>
                <a asp-area="KhachHang" asp-controller="KhachHang" asp-action="LichSuYeuCauThuGom" class="list-group-item list-group-item-action">
                    <i class="fas fa-recycle fa-fw me-2"></i> Lịch sử Thu gom
                </a>
                <a asp-area="KhachHang" asp-controller="KhachHang" asp-action="SanPhamChoDanhGia" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Action"]?.ToString() == "SanPhamChoDanhGia" ? "active" : "")">
                    <i class="fas fa-star fa-fw me-2 text-warning"></i> Chờ đánh giá
                </a>
                <a asp-area="KhachHang" asp-controller="KhachHang" asp-action="LichSuDanhGia" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Action"]?.ToString() == "LichSuDanhGia" ? "active" : "")">
                    <i class="fas fa-history fa-fw me-2 text-success"></i> Lịch sử đánh giá
                </a>
                <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword" class="list-group-item list-group-item-action">
                    <i class="fas fa-lock fa-fw me-2"></i> Đổi mật khẩu
                </a>
                <button type="submit" class="list-group-item list-group-item-action text-danger border-0 bg-transparent p-0 w-100 text-start">
                    <a href="/home/index" class="list-group-item list-group-item-action border-0 text-danger"><i class="fas fa-sign-out-alt fa-fw me-2"></i> Về trang chủ</a>
                </button>
            </div>
        </div>

        <div class="col-lg-9">
            <div class="account-content">
                <div class="ai-hero card border-0 shadow-sm mb-4 overflow-hidden">
                    <div class="card-body p-4 p-lg-5">
                        <div class="row g-4 align-items-start">
                            <div class="col-lg-7">
                                <span class="ai-hero-kicker">Bảng gợi ý thu mua thông minh</span>
                                <h1 class="ai-hero-title mt-2 mb-3">AI Matching doanh nghiệp</h1>
                                <p class="ai-hero-copy mb-0">Xin chào, @displayName. Hệ thống đang ưu tiên các sản phẩm phù hợp với nhu cầu, ở kho gần doanh nghiệp và có đủ khối lượng để bạn mua nhanh.</p>
                            </div>
                            <div class="col-lg-5">
                                <div class="ai-hero-panel">
                                    <div class="ai-hero-meta-label">Nhu cầu đang theo dõi</div>
                                    <div class="ai-hero-meta-value">@(Model?.KhachHangInfo?.NhuCauChinh ?? "Chưa khai báo nhu cầu")</div>
                                    <div class="row g-2 mt-3">
                                        <div class="col-sm-6">
                                            <div class="ai-hero-stat">
                                                <span class="ai-hero-stat-label">Số gợi ý</span>
                                                <strong>@(Model?.AIGoiYThuMua?.Count ?? 0)</strong>
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <div class="ai-hero-stat">
                                                <span class="ai-hero-stat-label">Địa chỉ doanh nghiệp</span>
                                                <strong>@(Model?.KhachHangInfo?.DiaChiDoanhNghiep ?? "Chưa cập nhật")</strong>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-success shadow-sm">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="fas fa-robot me-2"></i> Gợi ý Thu Mua Thông Minh</h5>
                        <span class="small">Điểm AI tổng hợp từ nhu cầu, khoảng cách và lượng tồn</span>
                    </div>
                    <div class="card-body p-0">
                        @if (Model?.AIGoiYThuMua != null && Model.AIGoiYThuMua.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Mã SP</th>
                                            <th>Kho</th>
                                            <th>Sản phẩm</th>
                                            <th>Khối lượng sẵn có</th>
                                            <th>Giá bán</th>
                                            <th>Điểm AI</th>
                                            <th>Hành động</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.AIGoiYThuMua)
                                        {
                                            <tr>
                                                <td><span class="fw-bold">@item.MaSanPham</span></td>
                                                <td>
                                                    <div class="fw-semibold">@item.TenKho</div>
                                                    <div class="small text-muted">@item.MaKho</div>
                                                    @if (!string.IsNullOrWhiteSpace(item.ProximityLabel))
                                                    {
                                                        <span class="badge bg-success-subtle text-success-emphasis border mt-1">@item.ProximityLabel</span>
                                                    }
                                                </td>
                                                <td>@item.TenSanPham</td>
                                                <td>
                                                    <div>Tổng kho gần nhất: @item.SoLuong.ToString("0.##") @item.DonViTinh</div>
                                                    <div class="small text-muted">@item.DiaChiKho</div>
                                                    @if (!string.IsNullOrWhiteSpace(item.SuggestedReason))
                                                    {
                                                        <div class="small text-success mt-1">@item.SuggestedReason</div>
                                                    }
                                                </td>
                                                <td>
                                                    <span class="fw-bold text-danger">@item.Gia.ToString("N0") ₫</span>
                                                </td>
                                                <td>
                                                    <div class="progress" style="height: 20px;">
                                                        <div class="progress-bar @(item.MatchScore >= 80 ? "bg-success" : (item.MatchScore >= 60 ? "bg-warning" : "bg-danger"))"
                                                             role="progressbar"
                                                             style="width: @item.MatchScore.ToString(System.Globalization.CultureInfo.InvariantCulture)%;"
                                                             aria-valuenow="@item.MatchScore"
                                                             aria-valuemin="0"
                                                             aria-valuemax="100">
                                                            @item.MatchScore%
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrWhiteSpace(item.MaSanPham) && item.SoLuong > 0)
                                                    {
                                                        <button type="button"
                                                                class="btn btn-sm btn-success w-100 mb-2 ai-buy-btn"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#aiBuyModal"
                                                                data-product-id="@item.MaSanPham"
                                                                data-product-name="@item.TenSanPham"
                                                                data-max-quantity="@item.SoLuong.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"
                                                                data-unit="@item.DonViTinh"
                                                                data-warehouse="@item.TenKho"
                                                                data-score="@item.MatchScore.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)">
                                                            Mua
                                                        </button>
                                                        <a asp-area="" asp-controller="DS_SP" asp-action="CT_SP" asp-route-id="@item.MaSanPham" class="btn btn-sm btn-outline-primary w-100 mb-2">Xem chi tiết</a>
                                                        @if (!string.IsNullOrWhiteSpace(item.M_YeuCau))
                                                        {
                                                            <a asp-area="KhachHang" asp-controller="KhachHang" asp-action="YeuCauThuGomDetails" asp-route-id="@item.M_YeuCau" class="btn btn-sm btn-outline-success w-100">Xem nguồn gốc</a>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted small">Sản phẩm chưa sẵn sàng để mua</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center p-4 text-muted">
                                <i class="fas fa-search-dollar fa-3x mb-3 text-secondary"></i>
                                <p>Hệ thống AI đang phân tích dữ liệu nhưng chưa có nguồn cung phù hợp với nhu cầu của bạn vào lúc này.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="aiBuyModal" tabindex="-1" aria-labelledby="aiBuyModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-area="" asp-controller="ShoppingCart" asp-action="BuyNow" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="aiBuyModalLabel">Mua sản phẩm gợi ý</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="productId" id="aiBuyProductId" />
                    <div class="mb-2 fw-semibold" id="aiBuyProductName">Sản phẩm</div>
                    <div class="small text-muted mb-3" id="aiBuyWarehouseInfo"></div>

                    <label for="aiBuyQuantity" class="form-label">Chọn khối lượng cần mua</label>
                    <input type="number"
                           class="form-control"
                           id="aiBuyQuantity"
                           name="khoiluong"
                           min="0.01"
                           step="0.01"
                           value="1"
                           required />
                    <div class="form-text" id="aiBuyQuantityHelp"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-success">Tiếp tục thanh toán</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const buyButtons = document.querySelectorAll('.ai-buy-btn');
        const productIdInput = document.getElementById('aiBuyProductId');
        const productName = document.getElementById('aiBuyProductName');
        const warehouseInfo = document.getElementById('aiBuyWarehouseInfo');
        const quantityInput = document.getElementById('aiBuyQuantity');
        const quantityHelp = document.getElementById('aiBuyQuantityHelp');

        buyButtons.forEach(function (button) {
            button.addEventListener('click', function () {
                const productId = button.dataset.productId || '';
                const name = button.dataset.productName || 'Sản phẩm';
                const warehouse = button.dataset.warehouse || 'Kho gợi ý';
                const unit = button.dataset.unit || 'kg';
                const score = button.dataset.score || '0';
                const maxQuantity = parseFloat(button.dataset.maxQuantity || '0');
                const defaultQuantity = maxQuantity >= 1 ? 1 : Math.max(maxQuantity, 0.01);

                productIdInput.value = productId;
                productName.textContent = name;
                warehouseInfo.textContent = 'Kho được chọn: ' + warehouse + ' | Điểm gợi ý AI: ' + score + '%';
                quantityInput.max = maxQuantity.toFixed(2);
                quantityInput.value = defaultQuantity.toFixed(2);
                quantityHelp.textContent = 'Có thể mua tối đa ' + maxQuantity.toFixed(2) + ' ' + unit + ' tại kho này.';
            });
        });
    });
</script>

<style>
    .ai-hero {
        background:
            radial-gradient(circle at top right, rgba(12, 140, 91, 0.18), transparent 32%),
            linear-gradient(135deg, #f8fffb 0%, #eef9f3 48%, #e2f4ea 100%);
    }

    .ai-hero-kicker {
        display: inline-block;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #198754;
        background: rgba(25, 135, 84, 0.12);
        padding: 0.45rem 0.7rem;
        border-radius: 999px;
    }

    .ai-hero-title {
        font-size: clamp(2rem, 4vw, 3.1rem);
        line-height: 1.05;
        color: #123524;
        max-width: 10ch;
    }

    .ai-hero-copy {
        font-size: 1.05rem;
        line-height: 1.8;
        color: #4b6357;
        max-width: 58ch;
    }

    .ai-hero-panel {
        background: rgba(255, 255, 255, 0.82);
        border: 1px solid rgba(25, 135, 84, 0.16);
        border-radius: 24px;
        padding: 1.2rem;
        backdrop-filter: blur(8px);
    }

    .ai-hero-meta-label,
    .ai-hero-stat-label {
        display: block;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #5c7b6c;
        margin-bottom: 0.35rem;
    }

    .ai-hero-meta-value {
        font-size: 1.15rem;
        font-weight: 700;
        line-height: 1.6;
        color: #123524;
        word-break: break-word;
    }

    .ai-hero-stat {
        height: 100%;
        background: #fff;
        border-radius: 18px;
        padding: 0.9rem 1rem;
        border: 1px solid rgba(25, 135, 84, 0.12);
    }

    .ai-hero-stat strong {
        display: block;
        font-size: 1rem;
        line-height: 1.6;
        color: #123524;
        word-break: break-word;
    }

    @@media (max-width: 991.98px) {
        .ai-hero-title {
            max-width: none;
        }
    }
</style>
