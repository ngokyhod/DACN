@model DACS.Models.ViewModels.KhachHangDashboardViewModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "AI Matching";
    var currentUser = await UserManager.GetUserAsync(User);
    var displayName = Model?.TenNguoiMua ?? currentUser?.FullName ?? User.Identity?.Name ?? "Khách";
}

<div class="container mt-4 account-section">
    <div class="row">
        <div class="col-lg-3 mb-4 mb-lg-0">
            @await Html.PartialAsync("~/Areas/KhachHang/Views/Shared/_AccountSidebar.cshtml")
        </div>

        <div class="col-lg-9">
            <div class="account-content">
                <section class="ai-header card border-0 shadow-sm mb-4">
                    <div class="card-body p-4">
                        <div class="d-flex flex-column flex-lg-row justify-content-between gap-4 align-items-start">
                            <div class="ai-header-copy">
                                <span class="ai-header-kicker">Bang goi y thu mua thong minh</span>
                                <h1 class="ai-header-title mb-2">AI Matching doanh nghiep</h1>
                                <p class="ai-header-text mb-0">Xin chao, @displayName. He thong uu tien cac san pham phu hop voi nhu cau, gan doanh nghiep va san hang de ban xu ly nhanh hon.</p>
                            </div>
                            <div class="ai-header-stats">
                                <div class="ai-info-card">
                                    <span class="ai-info-label">Nhu cau</span>
                                    <strong>@(Model?.KhachHangInfo?.NhuCauChinh ?? "Chua khai bao")</strong>
                                </div>
                                <div class="ai-info-card ai-info-card--small">
                                    <span class="ai-info-label">So goi y</span>
                                    <strong>@(Model?.AIGoiYThuMua?.Count ?? 0)</strong>
                                </div>
                                <div class="ai-info-card ai-info-card--small">
                                    <span class="ai-info-label">Dia chi</span>
                                    <strong>@(Model?.KhachHangInfo?.DiaChiDoanhNghiep ?? "Chua cap nhat")</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <div class="card border-success shadow-sm">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="fas fa-robot me-2"></i> Gợi ý Thu Mua Thông Minh</h5>
                        <span class="small">Điểm AI tổng hợp từ nhu cầu, khoảng cách và lượng tồn</span>
                    </div>
                    <div class="card-body p-0">
                        @if (Model?.AIGoiYThuMua != null && Model.AIGoiYThuMua.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Mã SP</th>
                                            <th>Kho</th>
                                            <th>Sản phẩm</th>
                                            <th>Khối lượng sẵn có</th>
                                            <th>Giá bán</th>
                                            <th>Điểm AI</th>
                                            <th>Hành động</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.AIGoiYThuMua)
                                        {
                                            <tr>
                                                <td><span class="fw-bold">@item.MaSanPham</span></td>
                                                <td>
                                                    <div class="fw-semibold">@item.TenKho</div>
                                                    <div class="small text-muted">@item.MaKho</div>
                                                    @if (!string.IsNullOrWhiteSpace(item.ProximityLabel))
                                                    {
                                                        <span class="badge bg-success-subtle text-success-emphasis border mt-1">@item.ProximityLabel</span>
                                                    }
                                                </td>
                                                <td>@item.TenSanPham</td>
                                                <td>
                                                    <div>Tổng kho gần nhất: @item.SoLuong.ToString("0.##") @item.DonViTinh</div>
                                                    <div class="small text-muted">@item.DiaChiKho</div>
                                                    @if (!string.IsNullOrWhiteSpace(item.SuggestedReason))
                                                    {
                                                        <div class="small text-success mt-1">@item.SuggestedReason</div>
                                                    }
                                                </td>
                                                <td>
                                                    <span class="fw-bold text-danger">@item.Gia.ToString("N0") ₫</span>
                                                </td>
                                                <td>
                                                    <div class="progress" style="height: 20px;">
                                                        <div class="progress-bar @(item.MatchScore >= 80 ? "bg-success" : (item.MatchScore >= 60 ? "bg-warning" : "bg-danger"))"
                                                             role="progressbar"
                                                             style="width: @item.MatchScore.ToString(System.Globalization.CultureInfo.InvariantCulture)%;"
                                                             aria-valuenow="@item.MatchScore"
                                                             aria-valuemin="0"
                                                             aria-valuemax="100">
                                                            @item.MatchScore%
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrWhiteSpace(item.MaSanPham) && item.SoLuong > 0)
                                                    {
                                                        <button type="button"
                                                                class="btn btn-sm btn-success w-100 mb-2 ai-buy-btn"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#aiBuyModal"
                                                                data-product-id="@item.MaSanPham"
                                                                data-product-name="@item.TenSanPham"
                                                                data-max-quantity="@item.SoLuong.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"
                                                                data-unit="@item.DonViTinh"
                                                                data-warehouse="@item.TenKho"
                                                                data-score="@item.MatchScore.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)">
                                                            Mua
                                                        </button>
                                                        <a asp-area="" asp-controller="DS_SP" asp-action="CT_SP" asp-route-id="@item.MaSanPham" class="btn btn-sm btn-outline-primary w-100 mb-2">Xem chi tiết</a>
                                                        @if (!string.IsNullOrWhiteSpace(item.M_YeuCau))
                                                        {
                                                            <a asp-area="KhachHang" asp-controller="KhachHang" asp-action="YeuCauThuGomDetails" asp-route-id="@item.M_YeuCau" class="btn btn-sm btn-outline-success w-100">Xem nguồn gốc</a>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted small">Sản phẩm chưa sẵn sàng để mua</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center p-4 text-muted">
                                <i class="fas fa-search-dollar fa-3x mb-3 text-secondary"></i>
                                <p>Hệ thống AI đang phân tích dữ liệu nhưng chưa có nguồn cung phù hợp với nhu cầu của bạn vào lúc này.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="aiBuyModal" tabindex="-1" aria-labelledby="aiBuyModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-area="" asp-controller="ShoppingCart" asp-action="BuyNow" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="aiBuyModalLabel">Mua sản phẩm gợi ý</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="productId" id="aiBuyProductId" />
                    <div class="mb-2 fw-semibold" id="aiBuyProductName">Sản phẩm</div>
                    <div class="small text-muted mb-3" id="aiBuyWarehouseInfo"></div>

                    <label for="aiBuyQuantity" class="form-label">Chọn khối lượng cần mua</label>
                    <input type="number"
                           class="form-control"
                           id="aiBuyQuantity"
                           name="khoiluong"
                           min="0.01"
                           step="0.01"
                           value="1"
                           required />
                    <div class="form-text" id="aiBuyQuantityHelp"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-success">Tiếp tục thanh toán</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const buyButtons = document.querySelectorAll('.ai-buy-btn');
        const productIdInput = document.getElementById('aiBuyProductId');
        const productName = document.getElementById('aiBuyProductName');
        const warehouseInfo = document.getElementById('aiBuyWarehouseInfo');
        const quantityInput = document.getElementById('aiBuyQuantity');
        const quantityHelp = document.getElementById('aiBuyQuantityHelp');

        buyButtons.forEach(function (button) {
            button.addEventListener('click', function () {
                const productId = button.dataset.productId || '';
                const name = button.dataset.productName || 'Sản phẩm';
                const warehouse = button.dataset.warehouse || 'Kho gợi ý';
                const unit = button.dataset.unit || 'kg';
                const score = button.dataset.score || '0';
                const maxQuantity = parseFloat(button.dataset.maxQuantity || '0');
                const defaultQuantity = maxQuantity >= 1 ? 1 : Math.max(maxQuantity, 0.01);

                productIdInput.value = productId;
                productName.textContent = name;
                warehouseInfo.textContent = 'Kho được chọn: ' + warehouse + ' | Điểm gợi ý AI: ' + score + '%';
                quantityInput.max = maxQuantity.toFixed(2);
                quantityInput.value = defaultQuantity.toFixed(2);
                quantityHelp.textContent = 'Có thể mua tối đa ' + maxQuantity.toFixed(2) + ' ' + unit + ' tại kho này.';
            });
        });
    });
</script>

<style>
    .ai-header {
        background:
            radial-gradient(circle at top right, rgba(25, 135, 84, 0.12), transparent 26%),
            linear-gradient(135deg, #fbfefc 0%, #f2faf5 100%);
        border-radius: 24px;
    }

    .ai-header-copy {
        max-width: 620px;
    }

    .ai-header-kicker {
        display: inline-block;
        font-size: 0.76rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: #198754;
        background: rgba(25, 135, 84, 0.12);
        padding: 0.4rem 0.75rem;
        border-radius: 999px;
    }

    .ai-header-title {
        margin-top: 0.9rem;
        font-size: clamp(1.9rem, 3vw, 2.6rem);
        line-height: 1.12;
        color: #123524;
    }

    .ai-header-text {
        font-size: 1rem;
        line-height: 1.75;
        color: #567264;
    }

    .ai-header-stats {
        min-width: min(100%, 360px);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.9rem;
    }

    .ai-info-card {
        grid-column: 1 / -1;
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid rgba(25, 135, 84, 0.12);
        border-radius: 18px;
        padding: 1rem 1.05rem;
    }

    .ai-info-card--small {
        grid-column: span 1;
    }

    .ai-info-label {
        display: inline-block;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #5c7b6c;
        margin-bottom: 0.45rem;
    }

    .ai-info-card strong {
        display: block;
        font-size: 1.02rem;
        line-height: 1.55;
        color: #123524;
        word-break: break-word;
    }

    @@media (max-width: 991.98px) {
        .ai-header-stats {
            min-width: 100%;
        }
    }

    @@media (max-width: 575.98px) {
        .ai-header-stats {
            grid-template-columns: 1fr;
        }

        .ai-info-card,
        .ai-info-card--small {
            grid-column: 1 / -1;
        }
    }
</style>
