@{
    ViewData["Title"] = $"Cập nhật TT Thanh toán ĐH {ViewBag.M_DonHang}";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/AdminLayout.css" />
    <style>
        body, html { height: 100%; }
        .container { display: grid; max-width: 100%; width: 100%; margin: 0; padding: 0; }
        .owner-layout { width: 100%; min-height: 100vh; align-items: stretch; }
        .main-content-area { padding: 25px; background-color: #f8f9fa; flex-grow: 1; overflow-y: auto; }
        .card-custom { background: #fff; border-radius: 0.375rem; padding: 20px; box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,.075); margin-bottom: 1.5rem; }
    </style>
</head>
<body>
    <div class="d-flex owner-layout">
        @await Html.PartialAsync("~/Areas/Owner/Views/Shared/_OwnerSidebar.cshtml")

        <div class="main-content-area">
            <h4 class="mb-4">@ViewData["Title"]</h4>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
            }

            <div class="card-custom" style="max-width:500px;">
                <form asp-action="UpdatePaymentStatus" asp-controller="QuanLyDonHang" asp-area="Owner" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@ViewBag.M_DonHang" />

                    <div class="mb-3">
                        <label for="newPaymentStatus" class="form-label fw-semibold">Trạng Thái Thanh Toán Mới</label>
                        <select name="newPaymentStatus" id="newPaymentStatus" class="form-select" asp-items="@ViewBag.PaymentStatusOptions" required>
                        </select>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i> Cập Nhật
                        </button>
                        <a asp-action="Details" asp-controller="QuanLyDonHang" asp-area="Owner" asp-route-id="@ViewBag.M_DonHang" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-2"></i> Quay Lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
