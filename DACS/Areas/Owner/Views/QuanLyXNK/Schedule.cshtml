@model DACS.Models.ViewModels.ScheduleViewModel

@{
    ViewData["Title"] = $"Lên lịch Thu gom - {Model.M_YeuCau}";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/AdminLayout.css" />
    <style>
        body, html { height: 100%; margin: 0; }
        .owner-layout { width: 100%; min-height: 100vh; align-items: stretch; }
        .main-content-area { padding: 25px; background-color: #f8f9fa; flex-grow: 1; overflow-y: auto; }
        .page-header { font-size: 1.75rem; font-weight: 500; margin-bottom: 1.5rem; color: #343a40; }
        .card-custom { background-color: #fff; padding: 1.5rem; border-radius: 0.375rem; box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,.075); margin-bottom: 1.5rem; }
        .info-label { font-weight: 600; color: #495057; }
    </style>
</head>
<body>
<div class="d-flex owner-layout">
    @await Html.PartialAsync("~/Areas/Owner/Views/Shared/_OwnerSidebar.cshtml")

    <div class="main-content-area">
        <div class="page-header">Lên lịch Thu gom cho Yêu cầu: @Model.M_YeuCau</div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="row">
            <div class="col-lg-7">
                <div class="card-custom">
                    <h5 class="mb-3 fw-semibold">Thông tin Yêu cầu</h5>
                    <div class="row mb-2">
                        <div class="col-sm-4 info-label">Mã Yêu Cầu</div>
                        <div class="col-sm-8">@Model.M_YeuCau</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4 info-label">Khách hàng</div>
                        <div class="col-sm-8">@Model.TenKhachHang</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4 info-label">Địa chỉ</div>
                        <div class="col-sm-8">@Model.DiaChiTomTat</div>
                    </div>
                </div>

                <div class="card-custom">
                    <h5 class="mb-3 fw-semibold">Đặt lịch hẹn</h5>
                    <form asp-action="Schedule" method="post">
                        <input asp-for="M_YeuCau" type="hidden" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="ThoiGianSanSang" class="form-label fw-semibold">Thời gian thu gom dự kiến</label>
                            <input asp-for="ThoiGianSanSang" type="datetime-local" class="form-control" />
                            <span asp-validation-for="ThoiGianSanSang" class="text-danger"></span>
                            <small class="form-text text-muted">Chọn ngày và giờ dự kiến đến thu gom.</small>
                        </div>

                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-check me-1"></i> Xác nhận Lịch hẹn
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times me-1"></i> Hủy bỏ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>