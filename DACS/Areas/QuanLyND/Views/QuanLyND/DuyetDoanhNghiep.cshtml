@model IEnumerable<DACS.Models.KhachHang>
@{
    ViewData["Title"] = "Duyệt Yêu Cầu Doanh Nghiệp";
}

<style>
    /* Basic CSS matching Owner Index */
    body, html {
        height: 100%;
        background-color: #f8f9fa; /* Changed to match Owner */
    }

    .container {
        display: grid;
        max-width: 100%;
        width: 100%;
        margin: 0;
        padding: 0;
        flex-direction: row;
    }

    .sidebar {
        background-color: #212529;
        color: #fff;
        padding: 15px;
        width: 250px;
        flex-shrink: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .sidebar h2 {
        border-bottom: 1px solid #495057;
        padding-bottom: 10px;
        font-size: 1.98rem;
        margin-bottom: 1rem;
        font-weight: 600;
        text-align: center; /* keep or adapt */
    }

    .sidebar .nav {
        flex-grow: 1;
    }

    .sidebar .nav-link {
        color: #adb5bd;
        padding: 8px 15px;
        border-radius: 0.25rem;
        margin-bottom: 5px;
        font-size: 0.9rem;
    }

    .sidebar .nav-link.active, .sidebar .nav-link:hover {
        color: #fff;
        background-color: #495057;
    }

    .sidebar .nav-item.mt-auto {
        margin-top: auto;
        border-top: 1px solid #495057;
        padding-top: 15px;
    }

    .main-content {
        padding: 25px;
        background-color: #f8f9fa;
        flex-grow: 1;
        overflow-y: auto;
    }

    .header {
        font-size: 1.5rem; /* larger header */
        font-weight: 500;
        margin-bottom: 1rem;
        color: #343a40;
    }

    .table th {
        font-weight: 600;
        font-size: 0.85rem;
    }

    .table td {
        font-size: 0.85rem;
        vertical-align: middle;
    }

    .table .actions form, .table .actions a, .table .actions button {
        margin-right: 3px;
        display: inline-block;
    }
    
    .table .badge {
        font-size: 0.75rem;
        padding: 0.3em 0.5em;
    }
</style>

@* --- Main Layout Container --- *@
<div class="d-flex">
    @* --- Sidebar --- *@
    <div class="sidebar">
        <h2>OWNER</h2>
        <ul class="nav flex-column">
            <li class="nav-item"><a asp-area="Owner" asp-controller="Owner" asp-action="Index" class="nav-link"><i class="fas fa-tachometer-alt me-2"></i> Dashboard</a></li>
            <li class="nav-item"><a asp-area="Owner" asp-controller="DoanhThu" asp-action="Index" class="nav-link"><i class="fas fa-chart-line me-2"></i> Doanh thu</a></li>
            <li class="nav-item"><a asp-area="Owner" asp-controller="QuanLyND" asp-action="Index" class="nav-link"><i class="fas fa-users me-2"></i> Quản lý Tài khoản</a></li>
            <li class="nav-item"><a asp-area="QuanLyND" asp-controller="QuanLyND" asp-action="DuyetDoanhNghiep" class="nav-link active"><i class="fas fa-building me-2"></i> Duyệt doanh nghiệp</a></li>
            <li class="nav-item"><a asp-area="Owner" asp-controller="QuanLySP" asp-action="Index" class="nav-link"><i class="fas fa-box-open me-2"></i> Quản lý Sản phẩm</a></li>
            <li class="nav-item"><a asp-area="Owner" asp-controller="QuanLyXNK" asp-action="Index" class="nav-link"><i class="fas fa-truck-loading me-2"></i> Quản lý Thu gom</a></li>
            <li class="nav-item"><a asp-area="Owner" asp-controller="QuanLyDonHang" asp-action="Index" class="nav-link"><i class="fas fa-receipt me-2"></i> Quản lý Đơn Hàng</a></li>
            <li class="nav-item"><a asp-area="Owner" asp-controller="QuanLyThanhToan" asp-action="Index" class="nav-link"><i class="fas fa-credit-card me-2"></i> Quản lý Thanh toán</a></li>
        </ul>
        <div class="nav-item mt-auto ">
            <button type="button" class="text-danger border-0 bg-transparent p-0 w-100 text-start mt-1">
                <a href="/home/index" class="border-0 text-danger" style="text-decoration: none;"><i class="fas fa-sign-out-alt fa-fw me-2"></i> Về trang chủ</a>
            </button>
        </div>
    </div>

    @* --- Main Content --- *@
    <div class="main-content flex-grow-1">
        <div class="header">Duyệt Yêu Cầu Doanh Nghiệp</div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                 @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="table-responsive bg-white p-3 rounded shadow-sm">
            <table class="table table-users table-striped table-hover table-sm caption-top" id="doanhNghiepTable">
                <caption>Danh sách đang chờ duyệt (@(Model?.Count() ?? 0) kết quả)</caption>
                <thead>
                    <tr>
                        <th>Mã KH</th>
                        <th>Họ Tên / SĐT</th>
                        <th>Tên Doanh Nghiệp</th>
                        <th>Lĩnh Vực Hoạt Động</th>
                        <th>Nhu Cầu Chính</th>
                        <th class="text-center">Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var kh in Model)
                        {
                            <tr>
                                <td><span class="fw-bold text-dark">@kh.M_KhachHang</span></td>
                                <td>
                                    <div>@kh.Ten_KhachHang</div>
                                    <div class="text-muted small"><i class="fas fa-phone-alt me-1"></i> @kh.SDT_KhachHang</div>
                                </td>
                                <td><span class="badge bg-info text-white">@kh.TenDoanhNghiep</span></td>
                                <td>@kh.LinhVucHoatDong</td>
                                <td class="text-muted small" style="max-width: 250px; white-space: normal;">@kh.NhuCauChinh</td>
                                <td class="text-center actions">
                                    <form asp-action="XacNhanDoanhNghiep" asp-route-id="@kh.M_KhachHang" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xác nhận cho doanh nghiệp: @kh.TenDoanhNghiep?');">
                                        <button type="submit" class="btn btn-success btn-sm me-1 shadow-sm" title="Xác nhận">
                                            <i class="fas fa-check me-1"></i>Duyệt
                                        </button>
                                    </form>
                                    <form asp-action="TuChoiDoanhNghiep" asp-route-id="@kh.M_KhachHang" method="post" class="d-inline" onsubmit="return confirm('Từ chối sẽ yêu cầu khách hàng này đăng ký lại. Tiếp tục?');">
                                        <button type="submit" class="btn btn-danger btn-sm shadow-sm" title="Từ chối">
                                            <i class="fas fa-times me-1"></i>Xóa
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted p-5">
                                <p class="mb-0">Hiện không có yêu cầu đăng ký doanh nghiệp nào mới.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>