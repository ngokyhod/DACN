@model DACS.Models.DonHang

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Thanh toán thành công</title>
</head>
<body style="font-family: Arial; background:#f2f4f7;">

    <div style="max-width:600px;margin:auto;background:#fff;padding:25px;border-radius:10px;text-align:center;">
        <h2 style="color:green;">✔ Thanh toán thành công!</h2>

        <p>Cảm ơn bạn đã thanh toán qua VNPAY.</p>

        <div style="background:#f8f9fa;padding:15px;border-radius:8px;text-align:left;">
            <strong>Mã đơn hàng:</strong> @Model.M_DonHang <br />
            <strong>Số tiền:</strong> @Model.TotalPrice.ToString("N0") VNĐ <br />
            <strong>Mã giao dịch:</strong> @Model.M_DonHang <br />
            <strong>Trạng thái:</strong> @Model.TrangThaiThanhToan <br />
        </div>

        <a href="/" style="display:inline-block;margin-top:20px;padding:10px 20px;background:#007bff;color:white;border-radius:5px;text-decoration:none;">Quay lại trang chủ</a>
    </div>

</body>
</html>
