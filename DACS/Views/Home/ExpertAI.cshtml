@{
    ViewData["Title"] = "Trợ lý AI Nông nghiệp";
}

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<style>
    :root {
        --bg-color: #f9f9f9;
        --sidebar-bg: #ffffff;
        --text-color: #1f1f1f;
        --chat-user-bg: #e9eef6;
        --chat-user-text: #1f1f1f;
        --input-bg: #ffffff;
        --input-border: #c4c7c5;
    }

    .container {
        display: grid;
        max-width: 100%;
        width: 100%;
        margin: 0;
        padding: 0;
        flex-direction: row;
    }
    [data-theme="dark"] {
        --bg-color: #343541;
        --sidebar-bg: #202123;
        --text-color: #ececf1;
        --chat-user-bg: #444654;
        --chat-user-text: #ececf1;
        --input-bg: #40414f;
        --input-border: #565869;
    }

    body {
        font-family: 'Inter', sans-serif;
        background-color: var(--bg-color);
        color: var(--text-color);
    }

    .chat-container {
        height: calc(100vh - 80px);
    }

    .sidebar {
        background: var(--sidebar-bg);
        border-right: 1px solid #e5e5e5;
    }

    /* Style cho mục lịch sử */
    .history-item {
        cursor: pointer;
        padding: 10px;
        border-radius: 6px;
        margin-bottom: 4px;
        font-size: 13px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: var(--text-color);
        transition: 0.2s;
        border: 1px solid transparent;
    }

        .history-item:hover {
            background-color: rgba(128,128,128,0.1);
        }

        .history-item.active {
            background-color: #e9eef6;
            border-color: #c4c7c5;
            font-weight: 600;
        }

    [data-theme="dark"] .history-item.active {
        background-color: #444654;
        border-color: #565869;
    }

    /* Các style khác giữ nguyên */
    #chatBox {
        scroll-behavior: smooth;
    }

    .message-row {
        display: flex;
        margin-bottom: 24px;
    }

        .message-row.user {
            justify-content: flex-end;
        }

    .message-content {
        max-width: 80%;
        padding: 12px 18px;
        border-radius: 12px;
        line-height: 1.6;
    }

    .user .message-content {
        background-color: var(--chat-user-bg);
        color: var(--chat-user-text);
    }

    .ai .message-content {
        padding-left: 0;
        color: var(--text-color);
    }

    .ai-avatar {
        width: 30px;
        height: 30px;
        margin-right: 12px;
        background: #10a37f;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
        flex-shrink: 0;
    }

    .input-area {
        background: var(--bg-color);
        padding: 24px;
        border-top: 1px solid #e5e5e5;
    }

    .custom-input {
        background-color: var(--input-bg);
        color: var(--text-color);
        border: 1px solid var(--input-border);
        border-radius: 12px;
        padding: 14px;
        padding-right: 100px;
    }

    .btn-action {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        border: none;
        background: none;
        cursor: pointer;
        z-index: 10;
    }

    .btn-send {
        right: 15px;
        color: #8e8ea0;
    }

    .btn-stop {
        right: 15px;
        color: #fff;
        background-color: #ef4444;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        display: none;
    }

    .btn-new-chat {
        width: 100%;
        border: 1px solid #ccc;
        padding: 10px;
        border-radius: 8px;
        background: transparent;
        color: var(--text-color);
        text-align: left;
        display: flex;
        gap: 10px;
        align-items: center;
    }
</style>

<div class="container-fluid p-0 chat-container d-flex">
    <div class="sidebar col-md-3 d-none d-md-block p-3 d-flex flex-column" style="height:100%">
        <button class="btn-new-chat mb-3" onclick="resetChat()">
            <i class="bi bi-plus-lg"></i> Cuộc trò chuyện mới
        </button>

        <div class="p-3 rounded mb-3" style="background: rgba(128,128,128,0.1);">
            <small><i class="bi bi-cpu"></i> <strong>Llama 3 (Streaming)</strong></small><br>
            <small style="font-size:10px">ID: <span id="sessId">...</span></small>
        </div>

        <div class="flex-grow-1 overflow-auto">
            <small class="text-muted fw-bold mb-2 d-block" style="font-size: 11px;">LỊCH SỬ GẦN ĐÂY</small>
            <div id="historyList">
                <div class="text-center text-muted mt-3" style="font-size:12px">Đang tải lịch sử...</div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
            <i class="bi bi-robot"></i> <small>Expert AI</small>
            <i class="bi bi-moon-stars-fill" style="cursor:pointer" onclick="toggleTheme()"></i>
        </div>
    </div>

    <div class="col-md-9 d-flex flex-column position-relative h-100">
        <div id="chatBox" class="flex-grow-1 p-4 overflow-auto">
            <div class="message-row ai">
                <div class="ai-avatar">AI</div>
                <div class="message-content">Xin chào! Tôi đã sẵn sàng.</div>
            </div>
        </div>

        <div id="loadingStatus" class="px-5 mb-2 text-muted fst-italic" style="display: none; font-size: 13px;">AI đang gõ...</div>

        <div class="input-area">
            <form id="chatForm" class="position-relative m-0">
                <input type="text" id="userInp" class="form-control custom-input" placeholder="Nhập câu hỏi..." autocomplete="off">
                <button id="btnSend" type="submit" class="btn-action btn-send"><i class="bi bi-send-fill fs-4"></i></button>
                <button id="btnStop" type="button" class="btn-action btn-stop" onclick="stopGeneration()"><i class="bi bi-stop-fill fs-5"></i></button>
            </form>
        </div>
    </div>
</div>

<script>
    // Khởi tạo
    function generateUUID() { return Math.random().toString(36).substring(2) + Date.now().toString(36); }
    const urlParams = new URLSearchParams(window.location.search);
    let currentSessionId = urlParams.get('session') || generateUUID();
    document.getElementById("sessId").innerText = currentSessionId.substring(0,8);
    let abortController = null;

    // Load dữ liệu ban đầu
    loadSessionsList();
    if(urlParams.get('session')) loadConversation(currentSessionId);

    async function loadSessionsList()
    {
        try {
            const res = await fetch('/History/GetSessions');
            const sessions = await res.json();
            const listHtml = document.getElementById("historyList");
            listHtml.innerHTML = ""; // Xóa chữ "Đang tải..."

            if (sessions.length === 0) {
                listHtml.innerHTML = `<div class="text-center text-muted mt-2" style="font-size:12px">Chưa có lịch sử</div>`;
                return;
            }

            // Vòng lặp này chính là "foreach" của bạn
            sessions.forEach(s => {
                const item = document.createElement("div");
                item.className = `history-item ${s.sessionId === currentSessionId ? 'active' : ''}`;

                // Hiển thị nội dung tóm tắt (Preview) cho đẹp
                let title = s.preview || "Cuộc hội thoại mới";
                if (title.length > 35) title = title.substring(0, 35) + "...";

                item.innerHTML = `<i class="bi bi-chat-text me-2"></i> ${title}`;

                // Bắt sự kiện click
                item.onclick = () => {
                    window.history.pushState({}, "", "?session=" + s.sessionId);
                    location.reload(); // Tải lại để cập nhật view
                };
                listHtml.appendChild(item);
            });
        } catch(e) { console.error("Lỗi tải lịch sử:", e); }
    }

    // --- HÀM 2: TẢI NỘI DUNG CUỘC TRÒ CHUYỆN ---
    async function loadConversation(sessionId) {
        try {
            const res = await fetch('/History/GetConversation?sessionId=' + sessionId);
            const messages = await res.json();
            const chatBox = document.getElementById("chatBox");
            chatBox.innerHTML = "";

            messages.forEach(m => {
                const role = m.isAi ? "ai" : "user";
                const avatar = m.isAi ? `<div class="ai-avatar">AI</div>` : "";
                const content = m.isAi ? marked.parse(m.content) : m.content;
                chatBox.innerHTML += `<div class="message-row ${role}">${avatar}<div class="message-content">${content}</div></div>`;
            });
            chatBox.scrollTop = chatBox.scrollHeight;
        } catch(e) { console.error(e); }
    }

    // --- HÀM 3: GỬI TIN NHẮN ---
    document.getElementById("chatForm").addEventListener("submit", async function(e) {
        e.preventDefault();
        const input = document.getElementById("userInp");
        const chatBox = document.getElementById("chatBox");
        const loader = document.getElementById("loadingStatus");
        const msg = input.value.trim();
        if (!msg) return;

        chatBox.innerHTML += `<div class="message-row user"><div class="message-content">${msg}</div></div>`;
        input.value = "";
        loader.style.display = "block";
        chatBox.scrollTop = chatBox.scrollHeight;
        toggleButtons(true);

        // Lưu User Msg
        await fetch('/History/SaveMessage', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ SessionId: currentSessionId, Content: msg, IsAi: false })
        });

        // Gọi Python Streaming
        abortController = new AbortController();
        let fullAiResponse = "";
        try {
            const response = await fetch('http://localhost:5000/chat', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ session_id: currentSessionId, question: msg }),
                signal: abortController.signal
            });

            loader.style.display = "none";
            const aiRow = document.createElement("div");
            aiRow.className = "message-row ai";
            aiRow.innerHTML = `<div class="ai-avatar">AI</div><div class="message-content"></div>`;
            chatBox.appendChild(aiRow);
            const contentDiv = aiRow.querySelector(".message-content");

            const reader = response.body.getReader();
            const decoder = new TextDecoder();
            while (true) {
                const { done, value } = await reader.read();
                if (done) break;
                const chunk = decoder.decode(value, { stream: true });
                fullAiResponse += chunk;
                contentDiv.innerHTML = marked.parse(fullAiResponse);
                chatBox.scrollTop = chatBox.scrollHeight;
            }
            // Lưu AI Msg
            await fetch('/History/SaveMessage', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ SessionId: currentSessionId, Content: fullAiResponse, IsAi: true })
            });

            // Reload sidebar nếu là tin nhắn đầu tiên
            if (document.getElementById("historyList").children.length <= 1) loadSessionsList();

        } catch (err) { if (err.name !== 'AbortError') alert("Lỗi: " + err); }
        finally { loader.style.display = "none"; toggleButtons(false); abortController = null; }
    });

    function resetChat() { window.location.href = window.location.pathname; }
    function stopGeneration() { if(abortController) abortController.abort(); }
    function toggleButtons(isGen) {
        document.getElementById("btnSend").style.display = isGen ? "none" : "block";
        document.getElementById("btnStop").style.display = isGen ? "flex" : "none";
    }
    function toggleTheme() {
        const b = document.body;
        const t = b.getAttribute('data-theme');
        b.setAttribute('data-theme', t==='dark'?'light':'dark');
    }
</script>