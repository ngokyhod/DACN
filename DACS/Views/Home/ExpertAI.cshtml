@{
    ViewData["Title"] = "Trợ lý AI Nông nghiệp";
}

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<style>
    :root {
        --bg-color: #f9f9f9;
        --sidebar-bg: #ffffff;
        --text-color: #1f1f1f;
        --chat-user-bg: #e9eef6;
        --chat-user-text: #1f1f1f;
        --input-bg: #ffffff;
        --input-border: #c4c7c5;
    }

    [data-theme="dark"] {
        --bg-color: #343541;
        --sidebar-bg: #202123;
        --text-color: #ececf1;
        --chat-user-bg: #444654;
        --chat-user-text: #ececf1;
        --input-bg: #40414f;
        --input-border: #565869;
    }

    body {
        font-family: 'Inter', sans-serif;
        background-color: var(--bg-color);
        color: var(--text-color);
    }

    .chat-container {
        height: calc(100vh - 80px);
    }

    .sidebar {
        background: var(--sidebar-bg);
        border-right: 1px solid #e5e5e5;
    }

    #chatBox {
        scroll-behavior: smooth;
    }

    .message-row {
        display: flex;
        margin-bottom: 24px;
    }

        .message-row.user {
            justify-content: flex-end;
        }

    .message-content {
        max-width: 80%;
        padding: 12px 18px;
        border-radius: 12px;
        line-height: 1.6;
    }

    .user .message-content {
        background-color: var(--chat-user-bg);
        color: var(--chat-user-text);
    }

    .ai .message-content {
        padding-left: 0;
        color: var(--text-color);
    }

    .ai-avatar {
        width: 30px;
        height: 30px;
        margin-right: 12px;
        background: #10a37f;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
        flex-shrink: 0;
    }

    .input-area {
        background: var(--bg-color);
        padding: 24px;
        border-top: 1px solid #e5e5e5;
    }

    .custom-input {
        background-color: var(--input-bg);
        color: var(--text-color);
        border: 1px solid var(--input-border);
        border-radius: 12px;
        padding: 14px;
        padding-right: 100px; /* Chừa chỗ cho 2 nút */
    }

    /* CSS CHO NÚT GỬI VÀ STOP */
    .btn-action {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        border: none;
        background: none;
        cursor: pointer;
        z-index: 10;
        transition: 0.2s;
    }

    .btn-send {
        right: 15px;
        color: #8e8ea0;
    }

        .btn-send:hover {
            color: #10a37f;
        }

    .btn-stop {
        right: 15px;
        color: #fff;
        background-color: #ef4444;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        display: none; /* Mặc định ẩn */
    }

        .btn-stop:hover {
            background-color: #dc2626;
        }

    .btn-new-chat {
        width: 100%;
        border: 1px solid #ccc;
        padding: 10px;
        border-radius: 8px;
        background: transparent;
        color: var(--text-color);
        text-align: left;
        display: flex;
        gap: 10px;
        align-items: center;
    }

        .btn-new-chat:hover {
            background-color: rgba(128,128,128,0.1);
        }
</style>

<div class="container-fluid p-0 chat-container d-flex">
    <div class="sidebar col-md-3 d-none d-md-block p-3 d-flex flex-column">
        <button class="btn-new-chat mb-4" onclick="resetChat()">
            <i class="bi bi-plus-lg"></i> Cuộc trò chuyện mới
        </button>
        <div class="mt-auto p-3 rounded" style="background: rgba(128,128,128,0.1);">
            <small><i class="bi bi-cpu"></i> <strong>Llama 3 (Streaming)</strong></small><br>
            <small style="font-size:10px">ID: <span id="sessId">...</span></small>
        </div>
    </div>

    <div class="col-md-9 d-flex flex-column position-relative h-100">
        <div id="chatBox" class="flex-grow-1 p-4 overflow-auto">
            <div class="message-row ai">
                <div class="ai-avatar">AI</div>
                <div class="message-content">Xin chào! Tôi sẽ trả lời kèm nguồn tài liệu tham khảo.</div>
            </div>
        </div>

        <div id="loadingStatus" class="px-5 mb-2 text-muted fst-italic" style="display: none; font-size: 13px;">AI đang gõ...</div>

        <div class="input-area">
            <form id="chatForm" class="position-relative m-0">
                <input type="text" id="userInp" class="form-control custom-input" placeholder="Nhập câu hỏi..." autocomplete="off">

                <button id="btnSend" type="submit" class="btn-action btn-send">
                    <i class="bi bi-send-fill fs-4"></i>
                </button>

                <button id="btnStop" type="button" class="btn-action btn-stop" onclick="stopGeneration()" title="Dừng trả lời">
                    <i class="bi bi-stop-fill fs-5"></i>
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    function generateUUID() { return Math.random().toString(36).substring(2) + Date.now().toString(36); }
    let currentSessionId = generateUUID();
    document.getElementById("sessId").innerText = currentSessionId.substring(0,8);

    // Biến điều khiển việc ngắt kết nối
    let abortController = null;

    function resetChat() {
        if(confirm("Tạo đoạn chat mới?")) {
            currentSessionId = generateUUID();
            document.getElementById("sessId").innerText = currentSessionId.substring(0,8);
            document.getElementById("chatBox").innerHTML = `<div class="message-row ai"><div class="ai-avatar">AI</div><div class="message-content">Đã reset! Mời bạn hỏi.</div></div>`;
        }
    }

    // --- HÀM STOP ---
    function stopGeneration() {
        if (abortController) {
            abortController.abort(); // Ngắt mạng ngay lập tức
            abortController = null;
            toggleButtons(false); // Hiện lại nút gửi
            document.getElementById("loadingStatus").style.display = "none";
        }
    }

    function toggleButtons(isGenerating) {
        if (isGenerating) {
            document.getElementById("btnSend").style.display = "none";
            document.getElementById("btnStop").style.display = "flex";
        } else {
            document.getElementById("btnSend").style.display = "block";
            document.getElementById("btnStop").style.display = "none";
        }
    }

    // --- HÀM GỬI TIN NHẮN ---
    document.getElementById("chatForm").addEventListener("submit", async function(e) {
        e.preventDefault();
        const input = document.getElementById("userInp");
        const chatBox = document.getElementById("chatBox");
        const loader = document.getElementById("loadingStatus");
        const msg = input.value.trim();
        if (!msg) return;

        // 1. Setup UI
        chatBox.innerHTML += `<div class="message-row user"><div class="message-content">${msg}</div></div>`;
        input.value = "";
        loader.style.display = "block";
        chatBox.scrollTop = chatBox.scrollHeight;

        // Bật nút Stop, Ẩn nút Gửi
        toggleButtons(true);

        // Tạo AbortController mới cho lần gửi này
        abortController = new AbortController();

        try {
            const response = await fetch('http://localhost:5000/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ session_id: currentSessionId, question: msg }),
                signal: abortController.signal // <--- Gắn tín hiệu ngắt vào đây
            });

            loader.style.display = "none";

            // Tạo khung tin nhắn AI
            const aiRow = document.createElement("div");
            aiRow.className = "message-row ai";
            aiRow.innerHTML = `<div class="ai-avatar">AI</div><div class="message-content"></div>`;
            chatBox.appendChild(aiRow);
            const contentDiv = aiRow.querySelector(".message-content");

            // Đọc Stream
            const reader = response.body.getReader();
            const decoder = new TextDecoder();
            let fullText = "";

            while (true) {
                const { done, value } = await reader.read();
                if (done) break;

                const chunk = decoder.decode(value, { stream: true });
                fullText += chunk;
                contentDiv.innerHTML = marked.parse(fullText);
                chatBox.scrollTop = chatBox.scrollHeight;
            }

        } catch (err) {
            if (err.name === 'AbortError') {
                console.log("Đã ngắt kết nối theo yêu cầu người dùng.");
                // Có thể thêm dòng thông báo "Đã dừng" nếu muốn
            } else {
                alert("Lỗi server: " + err);
            }
        } finally {
            loader.style.display = "none";
            toggleButtons(false); // Trả lại trạng thái ban đầu
            abortController = null;
        }
    });
</script>